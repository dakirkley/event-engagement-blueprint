{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "payment-page.html",
      "use": "@vercel/static"
    },
    {
      "src": "estimate-page.html",
      "use": "@vercel/static"
    },
    {
      "src": "CMA-estimate.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/payment",
      "dest": "/payment-page.html"
    },
    {
      "src": "/payment.html",
      "dest": "/payment-page.html"
    },
    {
      "src": "/estimate",
      "dest": "/estimate-page.html"
    },
    {
      "src": "/estimate.html",
      "dest": "/estimate-page.html"
    },
    {
      "src": "/ASAE-estimate",
      "dest": "/estimate-page.html"
    },
    {
      "src": "/ASAE-estimate.html",
      "dest": "/estimate-page.html"
    },
    {
      "src": "/CMA-estimate",
      "dest": "/CMA-estimate.html"
    },
    {
      "src": "/CMA-estimate.html",
      "dest": "/CMA-estimate.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
